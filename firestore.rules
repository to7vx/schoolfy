rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        // Check if user has admin role in users collection
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        // Check if user exists in admins collection and is active
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active') ||
        // Allow admin@schoolfy.com as fallback
        request.auth.token.email == 'admin@schoolfy.com'
      );
    }
    
    // Admins collection
    match /admins/{adminId} {
      // Admins can read/write their own admin document
      allow read, write: if request.auth != null && request.auth.uid == adminId;
      
      // Admins can read/write other admin documents (for admin management)
      allow read, write: if isAdmin();
      
      // Allow email-based queries for admin authentication
      allow read: if request.auth != null;
    }
    
    // Users collection (Guardians)
    match /users/{userId} {
      // Guardians can only read/write their own user document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Admins can read/write all user documents
      allow read, write: if isAdmin();
    }
    
    // Students collection
    match /students/{studentId} {
      // Allow reading students during phone linking process
      allow read: if request.auth != null;
      
      // Guardians can only read students they are linked to (after linking is complete)
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (request.auth.uid in get(/databases/$(database)/documents/students/$(studentId)).data.get('authorizedGuardianIds', []) ||
        get(/databases/$(database)/documents/students/$(studentId)).data.primaryGuardianId == 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guardianId);
      
      // Allow phone-based linking during authentication
      allow update: if request.auth != null &&
        // Only allow updating linking-related fields
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['primaryGuardianId', 'status', 'linkedAt']) &&
        // Guardian phone must match the student's guardianPhone
        request.auth.token.phone_number == resource.data.guardianPhone;
      
      // Only admins can write to students collection (full access)
      allow write: if isAdmin();
    }
    
    // Schools collection (read-only for guardians)
    match /schools/{schoolId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Authorized guardians subcollection
    match /students/{studentId}/authorizedGuardians/{guardianId} {
      // Primary guardian can manage authorized guardians
      allow read, write: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/students/$(studentId)).data.primaryGuardianId == 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guardianId;
      
      // Admins can manage all authorized guardians
      allow read, write: if isAdmin();
    }
    
    // Pickup logs collection
    match /pickupLogs/{logId} {
      // Admins can read and write pickup logs
      allow read, write: if isAdmin();
      
      // Guardians can read pickup logs for their own students
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        resource.data.guardianId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guardianId;
    }
    
    // Guardian authorization requests (if needed)
    match /authorizationRequests/{requestId} {
      // Admins can read and write authorization requests
      allow read, write: if isAdmin();
      
      // Guardians can read requests related to their students
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        resource.data.primaryGuardianId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guardianId;
    }
    
    // Grade leave times collection
    match /grade_leave_times/{gradeId} {
      // Admins can read and write grade leave times
      allow read, write: if isAdmin();
      
      // Guardians can read leave times for grades their students are in
      allow read: if request.auth != null;
    }
    
    // Guardian authorizations collection (for mobile app)
    match /guardian_authorizations/{authId} {
      // Admins can read and write guardian authorizations
      allow read, write: if isAdmin();
      
      // Guardians can read their own authorizations
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        resource.data.guardianId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.guardianId;
    }
    
    // Global settings collection (for admin dashboard)
    match /settings/{settingId} {
      // Only admins can read and write global settings
      allow read, write: if isAdmin();
    }
    
    // History/audit logs collection (for admin dashboard)
    match /history/{historyId} {
      // Only admins can read and write history logs
      allow read, write: if isAdmin();
    }
    
    // Automation service collection (for admin dashboard)
    match /automation/{automationId} {
      // Only admins can read and write automation settings
      allow read, write: if isAdmin();
    }
    
    // Notifications collection (for admin dashboard)
    match /notifications/{notificationId} {
      // Admins can read and write notifications
      allow read, write: if isAdmin();
      
      // Guardians can read notifications sent to them
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        resource.data.recipientId == request.auth.uid;
    }
    
    // System logs collection (for admin dashboard)
    match /systemLogs/{logId} {
      // Only admins can read and write system logs
      allow read, write: if isAdmin();
    }
    
    // Leave time history collection (for admin dashboard)
    match /leave_time_history/{historyId} {
      // Only admins can read and write leave time history
      allow read, write: if isAdmin();
    }
    
    // Scheduled notifications collection (for admin dashboard)
    match /scheduled_notifications/{notificationId} {
      // Only admins can read and write scheduled notifications
      allow read, write: if isAdmin();
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
