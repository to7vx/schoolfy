{
  "rules": {
    "pickupQueue": {
      ".read": true,
      ".write": false,
      "$date": {
        ".read": true,
        ".write": "auth != null",
        "$pickupId": {
          ".validate": "newData.hasChildren(['studentId', 'studentName', 'grade', 'guardianId', 'requestTime']) && auth != null"
        }
      }
    }
  }
}
