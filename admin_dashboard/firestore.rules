rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin Dashboard Access Rules
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == 'active';
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Admins collection - Only admins can read their own document
    match /admins/{adminId} {
      // Admin can read their own document
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      
      // Allow creation during setup (for creating admin accounts)
      allow create: if isAuthenticated();
      
      // Admin can update their own lastLoginAt
      allow update: if isAuthenticated() && 
                       request.auth.uid == adminId &&
                       onlyUpdatingFields(['lastLoginAt']);
    }
    
    // Users collection - Admin can manage all, users can manage their own
    match /users/{userId} {
      allow read, write: if isAdmin();
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated();
    }
    
    // Students collection - Admin full access, guardians limited access
    match /students/{studentId} {
      allow read, write, create, delete: if isAdmin();
      
      // Allow guardians to read students they are linked to
      allow read: if isAuthenticated() && 
                     request.auth.uid in resource.data.guardianIds;
                     
      // Allow guardians to read students where their phone matches (for initial linking)
      allow read: if isAuthenticated() && 
                     resource.data.guardianPhone == getAuthPhoneNumber();
                     
      // Allow guardians to list students for linking purposes
      allow list: if isAuthenticated();
      
      // Allow guardians to update students for linking (only specific fields)
      allow update: if isAuthenticated() && 
                       resource.data.guardianPhone == getAuthPhoneNumber() &&
                       onlyAllowedLinkingFields(request.resource.data, resource.data);
                     
      // Allow existing linked guardians to update limited fields
      allow update: if isAuthenticated() && 
                       request.auth.uid in resource.data.guardianIds &&
                       !('guardianIds' in request.resource.data.diff(resource.data).affectedKeys());
    }
    
    // Helper function to get phone number from authentication
    function getAuthPhoneNumber() {
      return request.auth.token.phone_number;
    }
    
    // Helper function to check only linking fields are updated
    function onlyAllowedLinkingFields(newData, oldData) {
      let allowedFields = ['primaryGuardianId', 'status', 'linkedAt'];
      let changedFields = newData.diff(oldData).affectedKeys();
      return changedFields.hasOnly(allowedFields);
    }
    
    // Guardian requests - Admin can manage all
    match /guardianRequests/{requestId} {
      allow read, write, create, delete: if isAdmin();
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && 
                     (request.auth.uid == resource.data.primaryGuardianId ||
                      request.auth.uid == resource.data.requestingGuardianId);
    }
    
    // Schools collection - Admin only
    match /schools/{schoolId} {
      allow read, write, create, delete: if isAdmin();
      allow read: if isAuthenticated();
    }
    
    // Pickup history - Admin full access, guardians limited
    match /pickupHistory/{historyId} {
      allow read, write, create, delete: if isAdmin();
      allow read: if isAuthenticated() && 
                     request.auth.uid == resource.data.guardianId;
    }
    
    // System settings - Admin only
    match /settings/{settingId} {
      allow read, write, create, delete: if isAdmin();
    }
    
    // Analytics data - Admin only  
    match /analytics/{docId} {
      allow read, write, create, delete: if isAdmin();
    }
    
    // Helper functions
    function onlyUpdatingFields(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(allowedFields);
    }
  }
}
